;; This configuration simply uses a 2nd layer to make the uio, jkl, m,. keys as a number pad

(defcfg
	process-unmapped-keys yes
)

(defcfg
	caps	u	i	o
		j	k	l
		m	,	.
)

(deflayer default
	@cap	_	_	_
		_	_	_
		_	_	_
)

(deflayer numpad
	_	7	8	9
		4	5	6
		1	2	3
)

(defalias
	cap (tap-hold-press 200 200 caps (layer-toggle numpad))
)
