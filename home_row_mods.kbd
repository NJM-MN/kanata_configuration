;; This config sets up mod-tap modifier keys in the home row of the keyboard

(defcfg
	process-unmapped-keys yes
)

(defsrc
	a s d f j k l ;
)

(defalias
	a-mod (tap-hold 200 200 a lalt)
	s-mod (tap-hold 200 200 s lmet)
	d-mod (tap-hold 200 200 d lsft)
	f-mod (tap-hold 200 200 f lctl)

	j-mod (tap-hold 200 200 j rctl)
	k-mod (tap-hold 200 200 k rsft)
	l-mod (tap-hold 200 200 l rmet)
	;-mod (tap-hold 200 200 ; ralt)
)

(deflayer base
 	@a-mod @s-mod @d-mod @f-mod	@j-mod @k-mod @l-mod @;-mod
)
